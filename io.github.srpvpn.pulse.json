{
  "app-id": "io.github.srpvpn.pulse",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "pulse",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "modules": [
    {
      "name": "pulse",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 build-aux/flatpak/pulse.sh /app/bin/pulse",
        "mkdir -p /app/share/pulse",
        "cp -r pulse /app/share/pulse/pulse",
        "install -Dm644 data/io.github.srpvpn.pulse.desktop /app/share/applications/io.github.srpvpn.pulse.desktop",
        "install -Dm644 data/io.github.srpvpn.pulse.metainfo.xml /app/share/metainfo/io.github.srpvpn.pulse.metainfo.xml",
        "install -Dm644 data/icons/hicolor/scalable/apps/io.github.srpvpn.pulse.svg /app/share/icons/hicolor/scalable/apps/io.github.srpvpn.pulse.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "./"
        }
      ]
    }
  ]
}
